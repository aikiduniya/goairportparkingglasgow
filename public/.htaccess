# Force HTTPS + non-www in a single 301 redirect (avoids redirect chains)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  Options -MultiViews
  DirectorySlash Off

  # Serve static SEO files directly - do NOT rewrite these
  RewriteRule ^sitemap\.xml$ - [L]
  RewriteRule ^robots\.txt$ - [L]
  RewriteRule ^google6f148081d631e709\.html$ - [L]

  # Redirect www/http/trailing-slash route variants to the final canonical URL in ONE 301
  RewriteCond %{HTTP_HOST} !^goairportparkingglasgow\.com$ [NC,OR]
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{REQUEST_URI} ^/(about|services|faqs|blogs|contact|testimonials|international|terms|privacy)/$ [NC]
  RewriteRule ^(about|services|faqs|blogs|contact|testimonials|international|terms|privacy)/?$ https://goairportparkingglasgow.com/$1 [R=301,L]

  # Redirect www -> non-www AND http -> https in ONE 301 for all other URLs
  RewriteCond %{HTTP_HOST} ^www\.goairportparkingglasgow\.com$ [NC,OR]
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://goairportparkingglasgow.com/$1 [R=301,L]

  # Serve public SEO routes as flat files so /about never redirects to /about/
  RewriteRule ^about$ about.html [L]
  RewriteRule ^services$ services.html [L]
  RewriteRule ^faqs$ faqs.html [L]
  RewriteRule ^blogs$ blogs.html [L]
  RewriteRule ^contact$ contact.html [L]
  RewriteRule ^testimonials$ testimonials.html [L]
  RewriteRule ^international$ international.html [L]
  RewriteRule ^terms$ terms.html [L]
  RewriteRule ^privacy$ privacy.html [L]
  RewriteRule ^blogs/([^/]+)$ blog-$1.html [L]

  # If the requested resource exists as a file or directory, serve it
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>

# Correct content types for SEO files
<IfModule mod_headers.c>
  <FilesMatch "sitemap\.xml$">
    Header set Content-Type "application/xml; charset=utf-8"
  </FilesMatch>
  <FilesMatch "robots\.txt$">
    Header set Content-Type "text/plain; charset=utf-8"
  </FilesMatch>
</IfModule>
